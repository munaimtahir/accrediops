    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*/",
        "destination": "http://127.0.0.1:8000/api/:path*/",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?/(?:/)?$"
      },
      {
        "source": "/api/:path*",
        "destination": "http://127.0.0.1:8000/api/:path*/",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
