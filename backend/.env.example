DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,phc.alshifalab.pk,api.phc.alshifalab.pk
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:18080,http://127.0.0.1:18080,https://phc.alshifalab.pk,https://api.phc.alshifalab.pk
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_PROXY_SSL_HEADER=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# AI Provider Configuration
# Set AI_PROVIDER to enable real AI generation: gemini, openai, anthropic
# Set AI_DEMO_MODE=true to use placeholder output without API keys (development/testing)
# If AI_DEMO_MODE=false and no provider is configured, AI generation will return a clear error.
AI_PROVIDER=gemini
AI_MODEL=gemini-1.5-flash
AI_DEMO_MODE=false
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
